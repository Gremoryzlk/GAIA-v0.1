{
  "module": "hermes",
  "version": "1.0",
  "agent_type": "hermes",
  "level": 1,
  "tools": [
    {
      "name": "web_search",
      "description": "Search the web for information"
    },
    {
      "name": "rss_fetch",
      "description": "Fetch RSS feed items from URL"
    }
  ],
  "subscribes_to": [
    "routing.request",
    "task.route"
  ],
  "publishes": [
    "tool.execute",
    "task.assigned",
    "routing.error"
  ]
}